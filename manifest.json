{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "__MSG_appShortName__",
  "version": "0.1.0",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.threads.net/*",
    "https://threads.net/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.threads.net/*",
        "https://threads.net/*"
      ],
      "js": ["src/i18n.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "action": {
    "default_title": "__MSG_actionTitle__"
  },
  "options_page": "src/sidepanel.html"
}
