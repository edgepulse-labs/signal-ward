# PCFA local development environment example
#
# Copy this file to `.env` for local-only development settings:
#
#   cp .env.example .env
#
# This project does not automatically load `.env` during normal extension runtime.
# For shell-based development tests, load it explicitly before running commands:
#
#   set -a
#   . ./.env
#   set +a
#   npm test
#
# Keep real secrets in `.env`; do not commit them.

# Optional OpenAI-compatible endpoint for developer-only tests.
# Pure unit tests should not require this value. Any test that uses it should be
# explicit, opt-in, and skipped by default when the variable is empty.
PCFA_TEST_OPENAI_COMPATIBLE_BASE_URL=https://ai.yihua.app/v1

# Optional API key for the developer-only OpenAI-compatible test endpoint.
# Leave empty unless the endpoint requires authentication.
PCFA_TEST_OPENAI_COMPATIBLE_API_KEY=

# Optional model id for developer-only OpenAI-compatible tests.
PCFA_TEST_OPENAI_COMPATIBLE_MODEL=

# Remote provider tests should remain disabled by default so `npm test` is fast,
# deterministic, and safe to run offline.
PCFA_TEST_ENABLE_REMOTE_OPENAI_COMPATIBLE=0

# Optional local endpoint override for local OpenAI-compatible tests.
PCFA_TEST_LOCAL_OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1

# Optional local model id for LM Studio or another local server.
PCFA_TEST_LOCAL_OPENAI_COMPATIBLE_MODEL=
